PROJECT_NAME=smartenv_gateway_support
ENV=dev

# =========================
# LLM / vLLM
# =========================
LLM_BASE_URL=http://127.0.0.1:10222/v1
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen2___5-7B-Instruct
LLM_TIMEOUT=60

# =========================
# Milvus
# =========================
MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB_NAME=default
MILVUS_TIMEOUT=10
MILVUS_COLLECTION_PREFIX=smartenv
MILVUS_COLLECTION_DOCS=smartenv_docs_v1
MILVUS_VECTOR_DIM=1024
MILVUS_METRIC_TYPE=COSINE

# =========================
# Embedding / Reranker
# =========================
EMBEDDING_MODEL_PATH=./models/bge-large-zh-v1.5
EMBEDDING_MODEL_NAME=bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

RERANKER_MODEL_PATH=./models/bge-reranker-v2-m3
RERANKER_MODEL_NAME=bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# =========================
# Project Paths
# =========================
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
UPLOAD_DIR=./data/uploads
LOG_DIR=./logs
# =========================
# LangSmith Observability
# =========================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=smartenv-se100-dev
# =========================
# Startup Warmup
# =========================
ENABLE_STARTUP_WARMUP=false

ES_URL=http://127.0.0.1:9200
ES_INDEX_NAME=smartenv_chunks_v1
ES_TIMEOUT=10